# ── Wallet / CLOB credentials ─────────────────────────────────────────────────
PRIVATE_KEY=your_polygon_private_key_here
FUNDER_ADDRESS=your_polygon_wallet_address_here
CHAIN_ID=137
SIGNATURE_TYPE=0

# ── Builder Program credentials ───────────────────────────────────────────────
# Get API credentials from: https://polymarket.com/settings?tab=builder
# Reference SDK: https://github.com/Polymarket/py-builder-signing-sdk
# Reference docs: https://docs.polymarket.com/builders/overview
#
# All three vars are required for builder attribution.
# The SDK uses HMAC-SHA256 signing — there is no "simple static signature" mode.
#
#   POLY_BUILDER_API_KEY      — your builder API key
#   POLY_BUILDER_SECRET       — base64url-encoded HMAC secret (from builder portal)
#   POLY_BUILDER_PASSPHRASE   — API passphrase
#
# These generate four headers on every CLOB order request:
#   POLY_BUILDER_API_KEY, POLY_BUILDER_TIMESTAMP,
#   POLY_BUILDER_PASSPHRASE, POLY_BUILDER_SIGNATURE
POLY_BUILDER_API_KEY=your_builder_api_key_here
POLY_BUILDER_SECRET=your_builder_secret_base64url_here
POLY_BUILDER_PASSPHRASE=your_builder_passphrase_here

# ── Bot control ───────────────────────────────────────────────────────────────
BOT_CONTROL_TOKEN=change_me_to_a_random_secret

# ── Optional overrides ────────────────────────────────────────────────────────
MAX_MARKETS=10
ORDER_SIZE_USDC=50.0
MAX_TOTAL_EXPOSURE_USDC=500.0
TARGET_SPREAD_PCT=0.02
MAX_SPREAD_PCT=0.05
DAILY_LOSS_LIMIT_USDC=100.0
LOG_LEVEL=INFO
PORT=8000

# ── CORS (comma-separated origins for dashboard) ──────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
