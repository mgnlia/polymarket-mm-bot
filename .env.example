# ── Wallet / CLOB credentials ─────────────────────────────────────────────────
PRIVATE_KEY=your_polygon_private_key_here
FUNDER_ADDRESS=your_polygon_wallet_address_here
CHAIN_ID=137
SIGNATURE_TYPE=0

# ── Builder Program credentials ───────────────────────────────────────────────
# Get your Builder ID from: https://polymarket.com/settings?tab=builder
# Reference: https://docs.polymarket.com/builders/overview
#
# Simple style (recommended for most users):
#   POLYMARKET_BUILDER_ID  — your builder wallet address / profile ID
#   POLYMARKET_BUILDER_SIGNATURE — static signature from the builder portal
POLYMARKET_BUILDER_ID=your_builder_wallet_address_here
POLYMARKET_BUILDER_SIGNATURE=your_static_builder_signature_here
#
# Full HMAC style (advanced — for dynamic per-request signing):
POLY_BUILDER_API_KEY=your_builder_api_key_here
POLY_BUILDER_SECRET=your_builder_secret_here
POLY_BUILDER_PASSPHRASE=your_builder_passphrase_here
#
# Relayer for gasless transactions:
POLY_RELAYER_HOST=https://relayer.polymarket.com

# ── Bot control ───────────────────────────────────────────────────────────────
BOT_CONTROL_TOKEN=change_me_to_a_random_secret

# ── Optional overrides ────────────────────────────────────────────────────────
MAX_MARKETS=10
ORDER_SIZE_USDC=50.0
MAX_TOTAL_EXPOSURE_USDC=500.0
TARGET_SPREAD_PCT=0.02
MAX_SPREAD_PCT=0.05
DAILY_LOSS_LIMIT_USDC=100.0
LOG_LEVEL=INFO
PORT=8000

# ── CORS (comma-separated origins for dashboard) ──────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
