# ── Polymarket CLOB credentials ──────────────────────────────────────────────
# Your Polygon wallet private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Your wallet address (the funder / proxy wallet)
FUNDER_ADDRESS=0xYourWalletAddress

# Chain: 137 = Polygon mainnet, 80002 = Amoy testnet
CHAIN_ID=137

# Signature type: 0 = EOA, 1 = Magic/email wallet, 2 = proxy wallet
SIGNATURE_TYPE=0

# ── Risk parameters (all configurable) ───────────────────────────────────────
# Max USDC per side per market
ORDER_SIZE_USDC=50.0

# Max net exposure per market
MAX_POSITION_PER_MARKET_USDC=50.0

# Total portfolio exposure cap
MAX_TOTAL_EXPOSURE_USDC=500.0

# Max drawdown before halt (0.20 = 20%)
MAX_DRAWDOWN_PCT=0.20

# Daily loss limit in USDC
DAILY_LOSS_LIMIT_USDC=100.0

# ── Spread config ─────────────────────────────────────────────────────────────
# Max spread (v in reward formula) — 0.05 = 5¢
MAX_SPREAD_PCT=0.05

# Target spread to quote at — tighter = more rewards
TARGET_SPREAD_PCT=0.02

# ── Market selection ──────────────────────────────────────────────────────────
MAX_MARKETS=10

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
